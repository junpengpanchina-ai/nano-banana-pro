# =============================================================================
# Supabase（数据库 + Auth + API）
# =============================================================================
#
# ① 应用走 HTTPS API（PostgREST / Auth），不写数据库 TCP 端口（默认 443）。
#    Dashboard → Project Settings → API：
#    - Project URL  → NEXT_PUBLIC_SUPABASE_URL
#    - anon public  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - service_role → SUPABASE_SERVICE_ROLE_KEY（仅 Vercel 服务端，勿泄露）
#
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# 管理后台 /admin（不走 Supabase 登录）
# =============================================================================
# /admin/login 独立账号密码（默认账号 admin；建议生产务必配置）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# 后台会话签名密钥（生产务必配置为随机长串，>=32 字符）
ADMIN_SESSION_SECRET=

# 可选：生成图 Storage 桶名（默认 generations，需先在 Dashboard 创建私有桶）
# SUPABASE_GENERATION_BUCKET=generations

# 内测：不校验、不扣 profiles.balance_images；仍写入 image_jobs / Storage。正式上线计费前删除或设为 0/false
# GENERATION_TESTING_MODE=1
#
# 与上一行同时开启时可选：免登录生成（/generate 与 POST /api/image/generate）。值为 Supabase 里已注册用户的 UUID（须有 profiles 行），所有匿名任务记在该用户下。
# ANONYMOUS_GENERATE_AS_USER_ID=

#
# ② 直连 PostgreSQL（可选：Drizzle / Prisma / psql / 数据分析）
#    Dashboard → Project Settings → Database → Connection string
#
#    直连（Session）：主机一般为 db.<project-ref>.supabase.co  端口 5432
#    DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
#
#    连接池 Transaction 模式（适合 Serverless 短连接）：端口 6543
#    DATABASE_URL=postgresql://postgres.<project-ref>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
#    本地 CLI `supabase start` 时 Postgres 端口见 supabase/config.toml 中 [db] port（默认 54322）。
#
# DATABASE_URL=

# =============================================================================
# 上游绘图（仅 Vercel 服务端）
# =============================================================================
UPSTREAM_API_KEY=
# 模型 id 由 lib/models.ts 配置，须与上游文档中的 model 字符串一致（如 nano-banana-fast）
#
# Grsai「Nano Banana」文档示例（国内直连，海外把 Host 换成文档里的 grsaiapi.com）：
# UPSTREAM_BASE_URL=https://grsai.dakka.com.cn
# UPSTREAM_DRAW_PATH=/v1/draw/nano-banana
# UPSTREAM_RESULT_PATH=/v1/draw/result
#
# 或两条完整 URL（须与文档路径一致）：
# UPSTREAM_DRAW_URL=https://grsai.dakka.com.cn/v1/draw/nano-banana
# UPSTREAM_RESULT_URL=https://grsai.dakka.com.cn/v1/draw/result
#
# 可选：参考图 URL，逗号分隔或 JSON 数组，会写入请求体 urls 字段（纯文生图可留空即传 []）
# UPSTREAM_REFERENCE_URLS=
# UPSTREAM_ASPECT_RATIO=auto
# UPSTREAM_BANANA_IMAGE_SIZE=1K
# UPSTREAM_POLL_INTERVAL_MS=2000
